<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_SPK" targetNamespace="http://spk-koperasi/bpmn">
  <bpmn:process id="Process_SPK" name="Alur Sistem SPK Koperasi" isExecutable="false">
    <bpmn:startEvent id="Start_Login" name="Mulai">
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Login" name="Isi email &#38; password">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Verifikasi" name="Verifikasi kredensial">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Login" name="Kredensial valid?">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:outgoing>f_login_ya</bpmn:outgoing>
      <bpmn:outgoing>f_login_tidak</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_GagalLogin" name="Gagal login">
      <bpmn:incoming>f_login_tidak</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Sesi" name="Buat sesi">
      <bpmn:incoming>f_login_ya</bpmn:incoming>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Dashboard" name="Tampilkan dashboard">
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Jalur" name="Jalur penyiapan model?">
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f_manual</bpmn:outgoing>
      <bpmn:outgoing>f_import</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_BuatManual" name="Buat model &#38; isi nama">
      <bpmn:incoming>f_manual</bpmn:incoming>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ModelDrafA" name="Buat Model SPK Draf">
      <bpmn:incoming>f6</bpmn:incoming>
      <bpmn:outgoing>f7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_PilihFile" name="Pilih file XLSX">
      <bpmn:incoming>f_import</bpmn:incoming>
      <bpmn:outgoing>f8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Parse" name="Parse &#38; validasi 2 sheet">
      <bpmn:incoming>f8</bpmn:incoming>
      <bpmn:outgoing>f9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Struktur" name="Struktur cocok &#38; tanpa error?">
      <bpmn:incoming>f9</bpmn:incoming>
      <bpmn:outgoing>f_struktur_ya</bpmn:outgoing>
      <bpmn:outgoing>f_struktur_tidak</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_ErrorImport" name="Import ditolak">
      <bpmn:incoming>f_struktur_tidak</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_ModelDrafB" name="Buat Model SPK Draf">
      <bpmn:incoming>f_struktur_ya</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_MergeSetup">
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:outgoing>f11</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Master" name="Isi data master (Expert, Kriteria, Alternatif, Kondisi)">
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:outgoing>f12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AHP" name="Isi perbandingan AHP (skala Saaty 1-9)">
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:outgoing>f13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_WP" name="Isi nilai strategi WP (skala 1-5)">
      <bpmn:incoming>f13</bpmn:incoming>
      <bpmn:outgoing>f14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_PilihSim" name="Pilih kondisi &#38; expert, klik Hitung Rekomendasi">
      <bpmn:incoming>f14</bpmn:incoming>
      <bpmn:outgoing>f15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Lengkap" name="Data lengkap?">
      <bpmn:incoming>f15</bpmn:incoming>
      <bpmn:outgoing>f_lengkap_ya</bpmn:outgoing>
      <bpmn:outgoing>f_lengkap_tidak</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_Batal" name="Hitung dibatalkan">
      <bpmn:incoming>f_lengkap_tidak</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_HitungAHP" name="Hitung AHP (geometric mean, bobot kriteria, CR)">
      <bpmn:incoming>f_lengkap_ya</bpmn:incoming>
      <bpmn:outgoing>f16</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_CR" name="CR &#60;= 0,1?">
      <bpmn:incoming>f16</bpmn:incoming>
      <bpmn:outgoing>f_cr_ya</bpmn:outgoing>
      <bpmn:outgoing>f_cr_tidak</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Konsisten" name="Tandai KONSISTEN">
      <bpmn:incoming>f_cr_ya</bpmn:incoming>
      <bpmn:outgoing>f17</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_TidakKonsisten" name="Tandai TIDAK konsisten (tetap lanjut)">
      <bpmn:incoming>f_cr_tidak</bpmn:incoming>
      <bpmn:outgoing>f18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_MergeCR">
      <bpmn:incoming>f17</bpmn:incoming>
      <bpmn:incoming>f18</bpmn:incoming>
      <bpmn:outgoing>f19</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_HitungWP" name="Hitung WP (benefit +bobot, cost -bobot, vektor S, vektor V)">
      <bpmn:incoming>f19</bpmn:incoming>
      <bpmn:outgoing>f20</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Tie" name="Selisih V &#60;= 0,0005?">
      <bpmn:incoming>f20</bpmn:incoming>
      <bpmn:outgoing>f_tie_ya</bpmn:outgoing>
      <bpmn:outgoing>f_tie_tidak</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Tie" name="Peringkat sama (tie)">
      <bpmn:incoming>f_tie_ya</bpmn:incoming>
      <bpmn:outgoing>f21</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Urut" name="Peringkat berurutan">
      <bpmn:incoming>f_tie_tidak</bpmn:incoming>
      <bpmn:outgoing>f22</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_MergeTie">
      <bpmn:incoming>f21</bpmn:incoming>
      <bpmn:incoming>f22</bpmn:incoming>
      <bpmn:outgoing>f23</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Ranking" name="Tampilkan ranking + rekomendasi terbaik (3 desimal)">
      <bpmn:incoming>f23</bpmn:incoming>
      <bpmn:outgoing>f24</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Simpan" name="Simpan riwayat kalkulasi (+ nama nasabah)">
      <bpmn:incoming>f24</bpmn:incoming>
      <bpmn:outgoing>f25</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Export" name="Lihat hasil, klik Export PDF">
      <bpmn:incoming>f25</bpmn:incoming>
      <bpmn:outgoing>f26</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Render" name="Hitung ulang &#38; render PDF">
      <bpmn:incoming>f26</bpmn:incoming>
      <bpmn:outgoing>f27</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Kirim" name="Kirim PDF ke browser">
      <bpmn:incoming>f27</bpmn:incoming>
      <bpmn:outgoing>f28</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Selesai" name="Selesai">
      <bpmn:incoming>f28</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="Start_Login" targetRef="Task_Login" />
    <bpmn:sequenceFlow id="f2" sourceRef="Task_Login" targetRef="Task_Verifikasi" />
    <bpmn:sequenceFlow id="f3" sourceRef="Task_Verifikasi" targetRef="GW_Login" />
    <bpmn:sequenceFlow id="f_login_ya" name="ya" sourceRef="GW_Login" targetRef="Task_Sesi" />
    <bpmn:sequenceFlow id="f_login_tidak" name="tidak" sourceRef="GW_Login" targetRef="End_GagalLogin" />
    <bpmn:sequenceFlow id="f4" sourceRef="Task_Sesi" targetRef="Task_Dashboard" />
    <bpmn:sequenceFlow id="f5" sourceRef="Task_Dashboard" targetRef="GW_Jalur" />
    <bpmn:sequenceFlow id="f_manual" name="Buat manual" sourceRef="GW_Jalur" targetRef="Task_BuatManual" />
    <bpmn:sequenceFlow id="f_import" name="Import XLSX" sourceRef="GW_Jalur" targetRef="Task_PilihFile" />
    <bpmn:sequenceFlow id="f6" sourceRef="Task_BuatManual" targetRef="Task_ModelDrafA" />
    <bpmn:sequenceFlow id="f7" sourceRef="Task_ModelDrafA" targetRef="GW_MergeSetup" />
    <bpmn:sequenceFlow id="f8" sourceRef="Task_PilihFile" targetRef="Task_Parse" />
    <bpmn:sequenceFlow id="f9" sourceRef="Task_Parse" targetRef="GW_Struktur" />
    <bpmn:sequenceFlow id="f_struktur_ya" name="ya" sourceRef="GW_Struktur" targetRef="Task_ModelDrafB" />
    <bpmn:sequenceFlow id="f_struktur_tidak" name="tidak" sourceRef="GW_Struktur" targetRef="End_ErrorImport" />
    <bpmn:sequenceFlow id="f10" sourceRef="Task_ModelDrafB" targetRef="GW_MergeSetup" />
    <bpmn:sequenceFlow id="f11" sourceRef="GW_MergeSetup" targetRef="Task_Master" />
    <bpmn:sequenceFlow id="f12" sourceRef="Task_Master" targetRef="Task_AHP" />
    <bpmn:sequenceFlow id="f13" sourceRef="Task_AHP" targetRef="Task_WP" />
    <bpmn:sequenceFlow id="f14" sourceRef="Task_WP" targetRef="Task_PilihSim" />
    <bpmn:sequenceFlow id="f15" sourceRef="Task_PilihSim" targetRef="GW_Lengkap" />
    <bpmn:sequenceFlow id="f_lengkap_ya" name="ya" sourceRef="GW_Lengkap" targetRef="Task_HitungAHP" />
    <bpmn:sequenceFlow id="f_lengkap_tidak" name="tidak" sourceRef="GW_Lengkap" targetRef="End_Batal" />
    <bpmn:sequenceFlow id="f16" sourceRef="Task_HitungAHP" targetRef="GW_CR" />
    <bpmn:sequenceFlow id="f_cr_ya" name="ya" sourceRef="GW_CR" targetRef="Task_Konsisten" />
    <bpmn:sequenceFlow id="f_cr_tidak" name="tidak" sourceRef="GW_CR" targetRef="Task_TidakKonsisten" />
    <bpmn:sequenceFlow id="f17" sourceRef="Task_Konsisten" targetRef="GW_MergeCR" />
    <bpmn:sequenceFlow id="f18" sourceRef="Task_TidakKonsisten" targetRef="GW_MergeCR" />
    <bpmn:sequenceFlow id="f19" sourceRef="GW_MergeCR" targetRef="Task_HitungWP" />
    <bpmn:sequenceFlow id="f20" sourceRef="Task_HitungWP" targetRef="GW_Tie" />
    <bpmn:sequenceFlow id="f_tie_ya" name="ya" sourceRef="GW_Tie" targetRef="Task_Tie" />
    <bpmn:sequenceFlow id="f_tie_tidak" name="tidak" sourceRef="GW_Tie" targetRef="Task_Urut" />
    <bpmn:sequenceFlow id="f21" sourceRef="Task_Tie" targetRef="GW_MergeTie" />
    <bpmn:sequenceFlow id="f22" sourceRef="Task_Urut" targetRef="GW_MergeTie" />
    <bpmn:sequenceFlow id="f23" sourceRef="GW_MergeTie" targetRef="Task_Ranking" />
    <bpmn:sequenceFlow id="f24" sourceRef="Task_Ranking" targetRef="Task_Simpan" />
    <bpmn:sequenceFlow id="f25" sourceRef="Task_Simpan" targetRef="Task_Export" />
    <bpmn:sequenceFlow id="f26" sourceRef="Task_Export" targetRef="Task_Render" />
    <bpmn:sequenceFlow id="f27" sourceRef="Task_Render" targetRef="Task_Kirim" />
    <bpmn:sequenceFlow id="f28" sourceRef="Task_Kirim" targetRef="End_Selesai" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Process_SPK">
    <bpmndi:BPMNPlane id="BPMNPlane_Process_SPK" bpmnElement="Process_SPK">
